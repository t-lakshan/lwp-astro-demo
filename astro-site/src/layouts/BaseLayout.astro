---
// BaseLayout — the shared page wrapper (like header.php + footer.php in WordPress).
// Loads the brand fonts and the full design stylesheet so every page looks like the design.
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'LivingWithPixels — A good system beats a thousand tutorials' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Sans:wght@600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap&v=7"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
