---
// Single Focused Guide page — one static page per guide (/guides/<slug>).
// Layout is designed/static in Astro; only the plain content comes from WordPress:
//   title, excerpt, price, buy-link (guide_buy_url), and the editor body (content.rendered).
// The cover visual reuses the same designed "number card" as the archive grid, so a
// guide's poster matches its card; if a guide has an uploaded guide_cover image, that
// renders instead. See project-decision-structured-guides.
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getGuides } from '../../lib/wp';

// Build one page per guide. We keep the same order + position numbering as the homepage
// grid so each guide's number-cover (01–04) and colour variant match its card there.
export async function getStaticPaths() {
  const guides = await getGuides();
  return guides.map((g: any, i: number) => ({
    params: { slug: g.slug },
    props: { guide: g, num: String(i + 1).padStart(2, '0'), variant: (i % 4) + 1 },
  }));
}

const { guide, num, variant } = Astro.props;
const title = guide.title.rendered;
const body = guide.content.rendered;
const { guide_format, guide_price, guide_excerpt, guide_cover, guide_buy_url } = guide.meta;
const buyLabel = `Get the guide — $${guide_price}`;
---

<BaseLayout>
  <main class="guide-page">
    <!-- HEADER BAND -->
    <section class="guide-hero">
      <div class="guide-wrap">
        <a class="guide-back" href="/#guides">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H6"/><path d="M12.5 5.5 6 12l6.5 6.5"/></svg>
          All guides
        </a>

        <div class="guide-hero-grid">
          <div class="guide-hero-left">
            <div class="section-label">Focused guide</div>
            <h1 class="title-2 guide-hero-title">{title}</h1>
            <p class="guide-hero-excerpt">{guide_excerpt}</p>
            <div class="guide-hero-actions">
              <a class="btn btn-lime" href={guide_buy_url} target="_blank" rel="noopener">{buyLabel}</a>
              <span class="guide-hero-meta">{guide_format} · ${guide_price}</span>
            </div>
          </div>

          <div class="guide-hero-visual">
            {guide_cover ? (
              <div class={`fg-cover fg-cover-${variant} has-image`} aria-hidden="true">
                <img src={guide_cover} alt="" />
              </div>
            ) : (
              <div class={`fg-cover fg-cover-${variant}`} aria-hidden="true">
                <div class="fg-cover-top">
                  <span class="fg-cover-brand">LWP</span>
                  <span>N° {num}</span>
                </div>
                <div class="fg-cover-mid">
                  <div class="fg-cover-num">{num}</div>
                  <div class="fg-cover-title">{title}</div>
                </div>
                <div class="fg-cover-bot">
                  <div class="fg-cover-pixels"><span></span><span></span><span></span></div>
                  <div class="fg-cover-fmt">{guide_format}</div>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- DESCRIPTION BAND (the WordPress editor body) -->
    <section class="guide-body">
      <div class="guide-prose boxed-s" set:html={body} />
    </section>

    <!-- CLOSING CTA -->
    <section class="guide-cta">
      <div class="guide-cta-inner">
        <h2 class="title-3 guide-cta-title">Ready to dive in?</h2>
        <p class="guide-cta-sub">{guide_format} · One focused problem, solved.</p>
        <a class="btn btn-lime" href={guide_buy_url} target="_blank" rel="noopener">{buyLabel}</a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ---- HEADER BAND ---- */
  .guide-hero {
    background: var(--brand-light-2);
    padding-block: var(--size-64) var(--size-80);
    padding-inline: var(--section-container);
  }
  .guide-wrap { max-width: 1100px; margin-inline: auto; }

  .guide-back {
    display: inline-flex;
    align-items: center;
    gap: var(--size-8);
    font-family: var(--body-font);
    font-weight: 600;
    font-size: var(--body-s);
    color: var(--brand-dark-2);
    text-decoration: none;
    margin-bottom: var(--size-48);
    transition: color 0.2s ease;
  }
  .guide-back:hover { color: var(--brand-accent); }
  .guide-back svg { width: 18px; height: 18px; }

  .guide-hero-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--size-64);
    align-items: center;
  }
  .guide-hero-left { min-width: 0; }
  .guide-hero-title { margin: var(--size-16) 0 var(--size-24); }
  .guide-hero-excerpt {
    font-size: var(--body-l);
    line-height: 1.7;
    color: var(--brand-dark-2);
    max-width: 520px;
    margin-bottom: var(--size-32);
  }
  .guide-hero-actions {
    display: flex;
    align-items: center;
    gap: var(--size-24);
    flex-wrap: wrap;
  }
  .guide-hero-meta {
    font-family: var(--body-font);
    font-weight: 600;
    font-size: var(--body-s);
    letter-spacing: 0.4px;
    color: var(--brand-dark-3);
    text-transform: uppercase;
  }
  /* Constrain the reused number-cover to a poster size in this column. */
  .guide-hero-visual { width: 320px; justify-self: end; }

  /* ---- DESCRIPTION BAND ---- */
  .guide-body {
    background: var(--brand-light-1);
    padding-block: var(--size-80);
    padding-inline: var(--section-container);
  }

  /* Prose styling for the WordPress editor body (set:html → needs :global). */
  .guide-prose :global(p) {
    font-size: var(--body-l);
    line-height: 1.7;
    color: var(--brand-dark-1);
    margin-bottom: var(--size-24);
  }
  .guide-prose :global(p:last-child) { margin-bottom: 0; }
  .guide-prose :global(h2),
  .guide-prose :global(h3),
  .guide-prose :global(h4) {
    font-family: var(--heading-font);
    font-weight: 800;
    color: var(--brand-dark-1);
    margin-top: var(--size-48);
    margin-bottom: var(--size-16);
  }
  .guide-prose :global(h2) { font-size: var(--title-size-4); letter-spacing: -0.4px; line-height: 1.15; }
  .guide-prose :global(h3) { font-size: var(--title-size-5); letter-spacing: -0.2px; line-height: 1.2; }
  .guide-prose :global(h4) { font-size: var(--title-size-6); line-height: 1.25; }
  .guide-prose :global(ul),
  .guide-prose :global(ol) {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--size-24);
  }
  .guide-prose :global(li) {
    position: relative;
    padding-left: var(--size-32);
    font-size: var(--body-l);
    line-height: 1.7;
    color: var(--brand-dark-1);
    margin-bottom: var(--size-12);
  }
  /* Lime diamond bullet with citrus-rind rim (8px → 1.5px rim, lime on light). */
  .guide-prose :global(li)::before {
    content: "";
    position: absolute;
    left: var(--size-4);
    top: 0.62em;
    width: 8px;
    height: 8px;
    background: var(--brand-2-accent);
    border: 1.5px solid var(--brand-2-accent-3);
    box-sizing: border-box;
    transform: rotate(45deg);
  }
  .guide-prose :global(a) {
    color: var(--brand-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .guide-prose :global(strong) { font-weight: 700; }

  /* ---- CLOSING CTA ---- */
  .guide-cta {
    background: var(--brand-light-3);
    padding-block: var(--size-80);
    padding-inline: var(--section-container);
  }
  .guide-cta-inner {
    max-width: 1100px;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--size-16);
  }
  .guide-cta-sub {
    font-size: var(--body-m);
    color: var(--brand-dark-2);
    margin-bottom: var(--size-8);
  }

  /* ---- RESPONSIVE ---- */
  @media (max-width: 960px) {
    .guide-hero-grid { grid-template-columns: 1fr; gap: var(--size-48); }
    .guide-hero-visual { justify-self: start; }
  }
  @media (max-width: 640px) {
    .guide-hero { padding-block: var(--size-48) var(--size-64); }
    .guide-hero-visual { width: 100%; max-width: 280px; }
  }
</style>
