---
// CtaBanner — small dark CTA strip. Hardcoded copy; no WP fields needed.
---

<section class="cta-banner section-s">
  <div class="cta-banner-inner">
    <div class="section-label light">Get started</div>
    <h2 class="section-title light">Stop collecting tutorials.<br>Start building systems.</h2>
    <p class="cta-banner-sub">
      Join 2,400+ web professionals who use LWP to work with AI without the overwhelm.
    </p>
    <div class="cta-banner-actions">
      <a href="#" class="btn btn-lime">Join the email club</a>
      <a href="#" class="btn btn-outline-dark">Browse the guides</a>
    </div>
  </div>
</section>

<style>
  .cta-banner {
    background: var(--brand-dark-1);
    padding-left:  var(--section-container);
    padding-right: var(--section-container);
  }

  .cta-banner-inner {
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--size-24);
  }

  .cta-banner .section-title {
    margin: 0;
  }

  .cta-banner-sub {
    font-family: var(--body-font);
    font-size: var(--body-l);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.65);
    max-width: 520px;
    margin: 0;
  }

  .cta-banner-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--size-12);
    justify-content: center;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .cta-banner-actions {
      flex-direction: column;
      width: 100%;
    }

    .cta-banner-actions .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
